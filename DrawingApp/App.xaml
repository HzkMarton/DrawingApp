<Application x:Class="DrawingApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DrawingApp"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="MainFont">./assets/#Comic Relief</FontFamily>
        <Brush x:Key="ForeGround">#B3B9C8</Brush>
        <Brush x:Key="BackGround">#151A28</Brush>
        <Brush x:Key="BorderColor">#1C2135</Brush>
    </Application.Resources>
</Application>
