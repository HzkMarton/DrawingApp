<Window x:Class="DrawingApp.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Színválasztó" Height="480" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource BackGround}">

    <StackPanel Margin="16" >
        <!-- Kör -->
        <Canvas x:Name="KorCanvas" Cursor="Cross" Width="300" Height="300" HorizontalAlignment="Center" MouseDown="Wheel_MouseDown" MouseMove="Wheel_MouseMove"/>
        <!-- Előnézet + Hex -->
        <Grid Margin="0 12 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Szinelonezet" Background="Black" Grid.Column="0" Height="40" Width="40" CornerRadius="100" BorderBrush="{DynamicResource ForeGround}" BorderThickness="2" Margin="0 0 8 0"/>
            <Border Grid.Column="1" Background="{DynamicResource BorderColor}" CornerRadius="20">
                <TextBox x:Name="HexBox" Text="#000000" Height="36" Background="Transparent" Foreground="{DynamicResource ForeGround}" BorderThickness="0" Padding="8 0" FontSize="20" FontFamily="{DynamicResource MainFont}" VerticalContentAlignment="Center" TextChanged="HexBox_TextChanged"/>
            </Border>
        </Grid>
        <!-- OK -->
        <Border CornerRadius="20" Background="{DynamicResource BorderColor}" Height="40" Width="200" Margin="0 20" MouseDown="Ok_Click" Cursor="Hand">
            <Label Content="OK" Foreground="{DynamicResource ForeGround}" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"></Label>
        </Border>
    </StackPanel>
</Window>
