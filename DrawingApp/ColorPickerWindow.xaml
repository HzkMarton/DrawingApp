<Window x:Class="DrawingApp.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Színválasztó" Height="480" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" >
        <!-- Kör -->
        <Canvas x:Name="KorCanvas" Width="300" Height="300" HorizontalAlignment="Center" MouseDown="Wheel_MouseDown" MouseMove="Wheel_MouseMove"/>
        <!-- Előnézet + Hex -->
        <Grid Margin="0 12 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Szinelonezet" Grid.Column="0" Height="36" CornerRadius="8" BorderBrush="#1C2135" BorderThickness="2" Margin="0 0 8 0"/>
            <TextBox x:Name="HexBox" Grid.Column="1" Height="36" FontSize="14" VerticalContentAlignment="Center" Padding="8 0" TextChanged="HexBox_TextChanged"/>
        </Grid>
        <!-- OK -->
        <Button Content="OK" Height="36" Margin="0 12 0 0" FontSize="14" Background="#1C2135" Foreground="White" Click="Ok_Click"/>
    </StackPanel>
</Window>
