<Window x:Class="DrawingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DrawingApp"
        mc:Ignorable="d"
        Title="Rajztábla" Height="450" Width="800" KeyDown="Window_KeyDown">
    <Grid x:Name="MainContainer">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MaxWidth="60" MinWidth="40"/>
            <ColumnDefinition Width="12*"/>
        </Grid.ColumnDefinitions>

        <!-- Eszközök -->
        <Border x:Name="ToolContainer"
                Visibility="Collapsed"
                Grid.Column="0"
                BorderBrush="#1C2135" BorderThickness="2"
                Margin="0 5 5 5" CornerRadius="5">
            <StackPanel Orientation="Vertical" x:Name="toolBar"/>
        </Border>

        <!-- Canvas -->
        <Grid x:Name="DrawingArea"
              Visibility="Collapsed"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="1*" MaxHeight="60" MinHeight="50"/>
            </Grid.RowDefinitions>
            <Border x:Name="CanvasContainer"
                    Grid.Row="0"
                    BorderBrush="#1C2135" Background="White"
                    BorderThickness="2" CornerRadius="10"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <InkCanvas Name="canvas" Background="Transparent"/>
            </Border>
            <Border x:Name="Menu"
                    Grid.Row="1"
                    BorderBrush="#1C2135" BorderThickness="2"
                    Margin="0 0 0 5" CornerRadius="5"/>
        </Grid>
        <!--Főmenü-->
        <Grid x:Name="MainMenuOverlay" Grid.ColumnSpan="2"
      Background="#151A28" Visibility="Visible" Panel.ZIndex="99">

            <!-- Startup-->
            <local:MainMenuView x:Name="MainMenuUserControl"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="360" Height="450"
                        Visibility="Visible"/>
            <!-- Pause-->
            <local:PauseMenu x:Name="PauseMenuUserControl"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Width="600" Height="450"
                     Visibility="Collapsed"/>
        </Grid>

    </Grid>
</Window>
