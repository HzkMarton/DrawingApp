<Window x:Class="DrawingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DrawingApp"
        mc:Ignorable="d"
        Title="Rajztábla" Height="450" Width="800">
    <Grid x:Name="MainContainer">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MaxWidth="60" MinWidth="40"></ColumnDefinition>
            <ColumnDefinition Width="12*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Border x:Name="ToolContainer" Grid.Row="1" Grid.Column="0" BorderBrush="#1C2135" BorderThickness="2" Margin="0 5 5 5" CornerRadius="5">
            <StackPanel Orientation="Vertical" x:Name="toolBar"></StackPanel>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*"></RowDefinition>
                <RowDefinition Height="1*" MaxHeight="60" MinHeight="50"></RowDefinition>
            </Grid.RowDefinitions>
            <Border x:Name="CanvasContainer" Grid.Row="0" Grid.Column="1" BorderBrush="#1C2135" Background="White" BorderThickness="2" CornerRadius="10"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <InkCanvas Name="canvas" Background="Transparent"></InkCanvas>
            </Border>
            <Border x:Name="Menu" Grid.Row="1" Grid.Column="0" BorderBrush="#1C2135" BorderThickness="2" Margin="0 0 0 5" CornerRadius="5">
             
            </Border>
        </Grid>
    </Grid>
</Window>
