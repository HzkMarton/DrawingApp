<Window x:Class="DrawingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DrawingApp"
        mc:Ignorable="d"
        Title="Rajztábla" Height="550" Width="800" PreviewKeyDown="Window_PreviewKeyDown" Background="{DynamicResource BackGround}">
    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource BackGround}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForeGround}"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource BackGround}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForeGround}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="10 4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"/>
                                <Path Grid.Column="2"
                                      x:Name="Arrow"
                                      Data="M 0 0 L 4 4 L 0 8"
                                      Stroke="White" StrokeThickness="1.5"
                                      VerticalAlignment="Center"
                                      Margin="8 0 2 0"
                                      Visibility="Collapsed"/>
                                <Popup x:Name="Popup"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       Focusable="False">
                                    <Border Background="{DynamicResource BackGround}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BorderColor}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BorderColor}"/>
                                <Setter TargetName="Arrow"  Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainContainer">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MaxHeight="27"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MaxWidth="60" MinWidth="40"/>
            <ColumnDefinition Width="12*"/>
        </Grid.ColumnDefinitions>

        <!-- Navbar -->
        <Viewbox Grid.Row="0" Grid.ColumnSpan="2"
          HorizontalAlignment="Left">
            <Menu 
          HorizontalAlignment="Stretch" FontSize="16" FontFamily="{StaticResource MainFont}">
                <MenuItem Header="Fájl">
                    <MenuItem Header="Új" Click="UjCanvas_Click"/>
                    <MenuItem Header="Betöltés" Click="Betoltes_Click"/>
                    <MenuItem Header="Mentés" Click="Mentes_Click"/>
                    <Separator/>
                    <MenuItem Header="Kilépés" Click="Exit_Click"/>
                </MenuItem>
                <MenuItem Header="Szerkesztés">
                    <MenuItem Header="Visszavonás" Click="Undo_Click"/>
                    <MenuItem Header="Újra" Click="Redo_Click"/>
                </MenuItem>
                <MenuItem Header="Nézet">
                    <MenuItem Header="Teljes képernyő" InputGestureText="F11" Click="FullScreen_Click"></MenuItem>
                    <MenuItem Header="Téma">
                        <MenuItem Header="Fekete" Click="TemaFekete_Click"/>
                        <MenuItem Header="Fehér" Click="TemaFeher_Click"/>
                        <MenuItem Header="Kék (alapértelmezett)" Click="TemaKek_Click"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Súgó">
                    <MenuItem Header="Információ" Click="Info_Click"/>
                </MenuItem>
            </Menu>
        </Viewbox>

        <!-- Eszközök -->
        <Border x:Name="ToolContainer" Grid.Row="1" Grid.Column="0" Margin="0 5 5 5" CornerRadius="5" Background="{DynamicResource BackGround}">
            <StackPanel Orientation="Vertical" x:Name="toolBar"/>
        </Border>

        <!-- Canvas -->
        <Grid x:Name="DrawingArea" Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="1*" MaxHeight="60" MinHeight="50"/>
            </Grid.RowDefinitions>
            <Border x:Name="CanvasContainer" Grid.Row="0"  Background="White" BorderThickness="2" CornerRadius="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <InkCanvas Name="canvas" Background="Transparent"/>
            </Border>
            <Border x:Name="Menu" Grid.Row="1" Margin="0 0 0 5" CornerRadius="5" Background="{DynamicResource BackGround}"/>
        </Grid>
    </Grid>
</Window>
